// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Contact {
  id                        Int       @id @default(autoincrement())
  submitted_at              DateTime  @default(now()) @db.Timestamp(6)
  first_name                String
  last_name                 String
  email                     String
  mobile                    String?   // Maps to Mobile field in Zoho CRM
  company                   String?
  service                   String?
  message                   String?
  ip_address                String?
  user_agent                String?
  assessment_data           Json?
  assessment_completed_at   DateTime? @db.Timestamp(6)
  assessment_score          Int?
  assessment_readiness_level String?

  // Professional Information (maps to Zoho CRM)
  job_title                 String?   // Maps to Designation in Zoho
  salutation                String?   // Mr, Mrs, Dr, etc.
  company_size              String?
  industry                  String?
  website                   String?
  annual_revenue            String?   // Maps to Annual_Revenue in Zoho
  no_of_employees           Int?      // Maps to No_of_Employees in Zoho
  rating                    String?   // Hot, Warm, Cold, etc.

  // Address Information (maps to Zoho CRM)
  street                    String?
  city                      String?
  state                     String?
  country                   String?
  zip_code                  String?

  // Contact Information (maps to Zoho CRM)
  skype_id                  String?
  secondary_email           String?
  twitter                   String?
  fax                       String?
  email_opt_out             Boolean?  @default(false)

  // Consultation Details
  preferred_date            DateTime? @db.Timestamp(6)
  preferred_time            String?
  timezone                  String?
  consultation_goals        String?
  current_challenges        String?
  budget                    String?
  timeline                  String?
  additional_notes          String?
  consultation_type         String?

  // Additional sections
  notes                     String?   // For additional comments/notes
  attachments               Json?     // Array of attachment objects with file info

  // Zoho CRM specific
  lead_status               String?   // Maps to Lead_Status in Zoho
  lead_source               String?   @default("Website")

  @@map("contacts")
}
